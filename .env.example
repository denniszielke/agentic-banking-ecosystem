# =============================================================================
# Agentic Banking Ecosystem — environment configuration sample
# =============================================================================
# Copy to `.env` and fill in the blanks. Most values are written automatically
# by `azd up` (from the outputs in infra/main.bicep); the ones with defaults
# below can be left as-is. Every variable is documented inline.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Azure context (written by `azd up`)
# -----------------------------------------------------------------------------
# Target resource group for all resources (defaults to rg-<AZURE_ENV_NAME>).
AZURE_RESOURCE_GROUP=
# Azure region the resources are deployed to (e.g. swedencentral).
AZURE_LOCATION=
# User-assigned managed identity used by the Container Apps to pull images and
# authenticate to Azure services (DefaultAzureCredential picks it up).
AZURE_IDENTITY_NAME=

# -----------------------------------------------------------------------------
# Azure Container Apps + Container Registry (written by `azd up`)
# -----------------------------------------------------------------------------
# Container Apps environment that hosts the MCP servers and agents.
AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_ID=
# ACR login server, e.g. myregistry.azurecr.io (both point at the same value).
AZURE_CONTAINER_REGISTRY_ENDPOINT=
AZURE_REGISTRY=

# -----------------------------------------------------------------------------
# Azure AI Search — vector indexes (written by `azd up`)
# -----------------------------------------------------------------------------
# Search service endpoint, e.g. https://<service>.search.windows.net
AZURE_SEARCH_ENDPOINT=
# Financial products vector index — product discovery / card comparison.
AZURE_SEARCH_FINANCIAL_PRODUCTS_INDEX_NAME=financial-products
# Compliance rules vector index — KYC/AML/sanctions/fraud scenarios.
AZURE_SEARCH_COMPLIANCE_RULES_INDEX_NAME=compliance-rules
# Admin key for indexing/ingestion (leave blank to use managed identity/RBAC).
AZURE_SEARCH_ADMIN_KEY=
# Search connection + service names on the AI project (written by `azd up`).
AZURE_AI_SEARCH_CONNECTION_NAME=
AZURE_AI_SEARCH_SERVICE_NAME=

# -----------------------------------------------------------------------------
# Azure AI Foundry project (written by `azd up`)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_PROJECT_ID=
AZURE_AI_PROJECT_NAME=

# -----------------------------------------------------------------------------
# Model deployments
# -----------------------------------------------------------------------------
# Chat model — gpt-5.4-mini, version 2026-03-17, deployment type GlobalStandard.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5.4-mini
# Embedding model used to build the vector indexes.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
# OpenAI REST API version used by the hosted apps/agents.
OPENAI_API_VERSION=2024-05-01-preview

# -----------------------------------------------------------------------------
# Telemetry — Application Insights / OpenTelemetry (written by `azd up`)
# -----------------------------------------------------------------------------
# Connection string all agents, MCP servers and apps publish OTel traces to.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# MCP server deployment (used by scripts/deploy_*_mcp_server.py)
# -----------------------------------------------------------------------------
# Image tag to deploy; set to the tag printed by scripts/build_containers.py
# (defaults to "latest" when unset).
TAG=latest

# customer_data_mcp_server — customers, accounts, balances, transactions.
CUSTOMER_MCP_APP_NAME=customer-data-mcp-server
CUSTOMER_MCP_PORT=8092
# "true" exposes public ingress so the Foundry project can reach it directly.
CUSTOMER_MCP_EXTERNAL=true

# product_data_mcp_server — product catalogue + per-customer holdings.
PRODUCT_MCP_APP_NAME=product-data-mcp-server
PRODUCT_MCP_PORT=8093
PRODUCT_MCP_EXTERNAL=true

# Directory the MCP servers load the synthetic data from (inside the image).
BANK_DATA_DIR=/app/data

# -----------------------------------------------------------------------------
# WorkIQ (Microsoft Agent 365) toolbox — employee advisory agent
# -----------------------------------------------------------------------------
# The employee advisory agent reaches an Agent 365 WorkIQ MCP server through the
# "workiq-tools" toolbox. WorkIQ authenticates via OAuth identity passthrough
# with a custom Entra app (see scripts/setup_workiq_oauth_app.py) — a static
# bearer token does NOT work (Foundry blocks Microsoft-audience tokens).
#
# There is no "McpServers.WorkIQ.All" scope / "mcp_WorkIQTools" server: WorkIQ is
# split into granular capabilities. Pick the server + scope you need.
WORKIQ_TOOLBOX_NAME=workiq-tools
WORKIQ_MCP_SERVER=mcp_CalendarTools
WORKIQ_SCOPE=McpServers.Calendar.All
# Entra tenant id (also emitted as AZURE_TENANT_ID by azd). Used in the MCP URL.
# WORKIQ_TENANT_ID=
# Custom OAuth app registration created by scripts/setup_workiq_oauth_app.py.
WORKIQ_OAUTH_APP_NAME=banking-workiq-oauth
# Foundry connection (OAuth identity passthrough) the toolbox references. Set the
# name (resolved to an id) or the full id. Create it in the Foundry portal using
# the values printed by scripts/setup_workiq_oauth_app.py.
WORKIQ_CONNECTION_NAME=workiq-connection
# WORKIQ_CONNECTION_ID=

# -----------------------------------------------------------------------------
# Idempotent re-run flags (used by infra deployment)
# -----------------------------------------------------------------------------
# Set to true on re-runs when connections already exist to avoid update conflicts.
SKIP_CONNECTION_CREATION=false
# Set to true on re-runs when role assignments already exist to avoid update conflicts.
SKIP_ROLE_ASSIGNMENTS=false
